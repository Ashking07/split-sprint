{
  "crons": [
    { "path": "/api/health", "schedule": "0 6 * * *" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    },
    "api/splitwise/connect.js": {
      "maxDuration": 10
    },
    "api/splitwise/callback.js": {
      "maxDuration": 10
    },
    "api/splitwise/status.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/splitwise/connect", "destination": "/api/splitwise/connect" },
    { "source": "/api/splitwise/callback", "destination": "/api/splitwise/callback" },
    { "source": "/api/splitwise/status", "destination": "/api/splitwise/status" },
    { "source": "/api/(.*)", "destination": "/api?path=$1" },
    { "source": "/((?!api/|assets/|manifest|sw|registerSW).*)", "destination": "/index.html" }
  ]
}
